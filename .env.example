# Application
APP_NAME=amza-commercial-ai-platform
APP_VERSION=0.1.0
DEBUG=false

# Database
DATABASE_URL=sqlite:///./data/amza.db

# OpenRouter (AI Provider)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Telegram (Channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Google OAuth (Security & Identity)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Debe apuntar al proxy de Next.js (BFF, spec 009), nunca directo al backend -- si no, la cookie
# de sesión queda con el origen equivocado y nunca viaja en las llamadas reales del frontend.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# JWT (Security & Identity)
JWT_SECRET=
JWT_TTL_HOURS=24

# Frontend -- BACKEND_URL es server-only, Next.js lo lee para el proxy (next.config.ts), nunca
# llega al navegador. Docker Compose lo inyecta vía env_file (este .env); en desarrollo local
# (npm run dev, sin Docker) Next.js NO lee este archivo -- usar frontend/.env.local en su lugar.
BACKEND_URL=http://localhost:8000
